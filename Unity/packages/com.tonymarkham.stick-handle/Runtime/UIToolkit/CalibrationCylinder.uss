#root-container {
    flex-grow: 1;
}

#top-row,
#middle-row,
#bottom-row {
    flex-grow: 1;
    flex-direction: row;
}

#top-row-left, #top-row-middle, #top-row-right,
#middle-row-left, #middle-row-middle, #middle-row-right,
#bottom-row-left, #bottom-row-middle, #bottom-row-right {
    flex-grow: 1;
}

.direction-label {
    -unity-text-align: middle-center;
    font-size: 72px;
}
